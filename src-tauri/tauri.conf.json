{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "short_video",
  "version": "0.2.0",
  "identifier": "com.wnx.shortvideo",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI内容创作平台",
        "width": 1200,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": "default-src 'self' data: file: ws: http: https: 'unsafe-inline' 'unsafe-eval'",
      "assetProtocol": {
        "scope": ["**"],
        "enable": true
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "bin/ffmpeg.exe"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"],
        "compression": "zlib"
      }
    }
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}
